# Copy to `.env` to override. All values are optional — code defaults in
# src/lib/constants.ts apply when unset, so the app runs without a .env.
# Only VITE_-prefixed vars are exposed to the client by Vite.

# USGS FDSNWS event query endpoint
VITE_USGS_API_URL=https://earthquake.usgs.gov/fdsnws/event/1/query

# MapLibre basemap style (OpenFreeMap — free, keyless)
VITE_BASEMAP_STYLE_URL=https://tiles.openfreemap.org/styles/positron
